                                </con3:location>
                                <con3:expr>
                                    <con1:xqueryText><![CDATA[<ema:EmailRequest xmlns:ema="http://www.km.qa/email">
    <ema:Subject>{concat('OSB:Alert | Critical Failure in ',$varLogPayload//*:Interface_Name/text())}</ema:Subject>
    <ema:From>{dvm:lookup('COMMON_UTIL_FRAMEWORK/Resources/DVM/CommonEmailConfig.dvm','Application','From','Email','')}</ema:From>
    <ema:To>{dvm:lookup('COMMON_UTIL_FRAMEWORK/Resources/DVM/CommonEmailConfig.dvm','Application',substring($varLogPayload//*:Interface_Name/text(),1,4),'Email','')}</ema:To>
    <ema:Cc></ema:Cc>
    <ema:Bcc></ema:Bcc>
    <ema:SendEmailAsAttachment></ema:SendEmailAsAttachment>
    <ema:Timestamp>{fn:current-dateTime()}</ema:Timestamp>
    <ema:TrackingID>{$varLogPayload//*:Service_Hdr_Unique_Id/text()}</ema:TrackingID>
    <ema:ModuleName>{$varLogPayload//*:Module_Name/text()}</ema:ModuleName>
    <ema:SourceSystem>{$varLogPayload//*:Source_System/text()}</ema:SourceSystem>
    <ema:TargetSystem>{$varLogPayload//*:Target_System/text()}</ema:TargetSystem>
    <ema:ServiceName>{$varLogPayload//*:Interface_Name/text()}</ema:ServiceName>
    <ema:Payload>{$varIntialRequest}</ema:Payload>
    {
      if($varFault//*:faultcode !='')then
        <ema:FaultName>{$varFault//*:faultcode}</ema:FaultName>
      else(<ema:FaultName>{$fault/ctx:errorCode/text()}</ema:FaultName>)
    }
    {
      if($varFault//*:faultcode !='')then
        <ema:FaultDesc>{fn:substring($varFault,1,1500)}</ema:FaultDesc>
      else(<ema:FaultDesc>{$fault/*:reason/text()}</ema:FaultDesc>)
    }
    <ema:Status>Error</ema:Status>
</ema:EmailRequest>]]></con1:xqueryText>
                                </con3:expr>
