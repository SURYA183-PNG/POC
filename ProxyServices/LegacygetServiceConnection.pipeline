                        <con5:outboundTransform>
                            <con2:routing-options xmlns:con2="http://www.bea.com/wli/sb/stages/transform/config" xmlns:con1="http://www.bea.com/wli/sb/stages/publish/config">
                                <con6:id xmlns:con6="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e1980e.N271b888c.0.16eb10d1665.N781b</con6:id>
