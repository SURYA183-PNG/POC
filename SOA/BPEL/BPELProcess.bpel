<?xml version = "1.0" encoding = "UTF-8" ?>
<!--
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  Oracle JDeveloper BPEL Designer 
  
  Created: Thu Apr 23 18:01:43 IST 2026
  Author:  LakshmikanthanT
  Type: BPEL 2.0 Process
  Purpose: Synchronous BPEL Process
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
-->
<process name="BPELProcess"
               targetNamespace="http://xmlns.oracle.com/SOA/EvenorODDRest/BPELProcess"
               xmlns="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
               xmlns:client="http://xmlns.oracle.com/SOA/EvenorODDRest/BPELProcess"
               xmlns:ora="http://schemas.oracle.com/xpath/extension"
               xmlns:ui="http://xmlns.oracle.com/soa/designer"
               xmlns:bpelx="http://schemas.oracle.com/bpel/extension"
         xmlns:bpel="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
         xmlns:ns1="http://xmlns.oracle.com/SOA/EvenorODDRest/EvenorOdd" xmlns:ns2="http://www.example.org">
    <!-- 
      ////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
        PARTNERLINKS                                                      
        List of services participating in this BPEL process               
      ////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
    -->
  <import namespace="http://xmlns.oracle.com/SOA/EvenorODDRest/EvenorOdd" location="../WSDLs/EvenorOdd.wsdl"
          importType="http://schemas.xmlsoap.org/wsdl/" ui:processWSDL="true"/>
  <partnerLinks>
    <!-- 
      The 'client' role represents the requester of this service. It is 
      used for callback. The location and correlation information associated
      with the client role are automatically set using WS-Addressing.
    -->
    <partnerLink name="EvenorOdd" partnerLinkType="ns1:EvenorOdd" myRole="EvenorOddProvider"/>
  </partnerLinks>

  <!-- 
    ////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
      VARIABLES                                                        
      List of messages and XML documents used within this BPEL process 
    ////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  -->
  <variables>
    <!-- Reference to the message passed as input during initiation -->

    <!-- Reference to the message that will be returned to the requester-->
    <variable name="receiveInput_Operation1_InputVariable" messageType="ns1:Operation1_inputMessage"/>
    <variable name="replyOutput_Operation1_OutputVariable" messageType="ns1:Operation1_outputMessage"/>
  </variables>

  <!-- 
    ////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
     ORCHESTRATION LOGIC                                               
     Set of activities coordinating the flow of messages across the    
     services integrated within this business process                  
    ////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  -->
  <sequence name="main">

    <!-- Receive input from requestor. (Note: This maps to operation defined in BPELProcess.wsdl) -->
    <receive name="receiveInput" partnerLink="EvenorOdd" portType="ns1:EvenorOdd_ptt" operation="Operation1"
             variable="receiveInput_Operation1_InputVariable" createInstance="yes"/>
    <if name="If1">
      <documentation>
        <![CDATA[even]]>
      </documentation>
      <condition expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath1.0">$receiveInput_Operation1_InputVariable.request/ns2:number mod 2 = 0</condition>
      <assign name="Assign1">
        <copy>
          <from>'Even'</from>
          <to expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath1.0">$replyOutput_Operation1_OutputVariable.reply/ns2:result</to>
        </copy>
      </assign>
      <else>
        <documentation>
          <![CDATA[else]]>
        </documentation>
        <assign name="Assign2">
          <copy>
            <from>'Odd'</from>
            <to expressionLanguage="urn:oasis:names:tc:wsbpel:2.0:sublang:xpath1.0">$replyOutput_Operation1_OutputVariable.reply/ns2:result</to>
          </copy>
        </assign>
      </else>
    </if>
    <!-- Generate reply to synchronous request -->
    <reply name="replyOutput" partnerLink="EvenorOdd" portType="ns1:EvenorOdd_ptt" operation="Operation1"
           variable="replyOutput_Operation1_OutputVariable"/>
  </sequence>
</process>