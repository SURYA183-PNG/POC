<?xml version= '1.0' encoding= 'UTF-8' ?>
<wsdl:definitions
     name="Rest"
     targetNamespace="http://xmlns.oracle.com/SOA/EvenorODDSoap/Rest"
     xmlns:tns="http://xmlns.oracle.com/SOA/EvenorODDSoap/Rest"
     xmlns:inp1="http://www.example.org"
     xmlns:inp2="http://www.example.org"
     xmlns:plnk="http://docs.oasis-open.org/wsbpel/2.0/plnktype"
     xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
    >
    <plnk:partnerLinkType name="Rest">
        <plnk:role name="RestProvider" portType="tns:Rest_ptt"/>
    </plnk:partnerLinkType>
    <wsdl:types>
        <xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">
            <xsd:import namespace="http://www.example.org" schemaLocation="../Schemas/RestInput.xsd"/>
        </xsd:schema>
        <xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">
            <xsd:import namespace="http://www.example.org" schemaLocation="../Schemas/RestOut.xsd"/>
        </xsd:schema>
    </wsdl:types>
    <wsdl:message name="Rest_inputMessage">
        <wsdl:part name="request" element="inp1:checkRequest"/>
    </wsdl:message>
    <wsdl:message name="Rest_outputMessage">
        <wsdl:part name="reply" element="inp1:checkResponse"/>
    </wsdl:message>
    <wsdl:portType name="Rest_ptt">
        <wsdl:operation name="Rest">
            <wsdl:input message="tns:Rest_inputMessage"/>
            <wsdl:output message="tns:Rest_outputMessage"/>
        </wsdl:operation>
    </wsdl:portType>
</wsdl:definitions>
